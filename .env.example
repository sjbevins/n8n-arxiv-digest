# ============================================================
# arXiv Digest - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# ============================================================

# --- n8n Settings ---

# Username for n8n login page
N8N_BASIC_AUTH_USER=your-n8n-username

# Password for n8n login page (use something strong)
N8N_BASIC_AUTH_PASSWORD=your-strong-password-here

# Your server's LAN IP address (used for Google OAuth redirect).
# Find your IP with: hostname -I | awk '{print $1}'
# The .nip.io suffix lets Google OAuth work with a bare IP address.
# Example: if your IP is 192.168.1.50, set this to:
#   http://192.168.1.50.nip.io:5678/
WEBHOOK_URL=http://YOUR_LAN_IP.nip.io:5678/

# Your timezone (IANA format)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# Docker group GID on your host system.
# n8n needs this to start/stop the Flask scraper container via the Docker socket.
# Find it with: getent group docker | cut -d: -f3
# Common values: 988, 999, or 998 (varies by system)
DOCKER_GID=988

# --- Credentials configured in n8n UI (not used by Docker Compose) ---
# These are listed here as a checklist. You will enter them in the n8n
# web interface under Settings > Credentials, NOT in this file.

# Gmail App Password for sending digest emails.
# See README Step 4 for how to generate one.
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-16-char-app-password

# Anthropic API key for Claude paper summaries.
# Get one at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here
